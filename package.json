{
  "name": "ha-reef-card",
  "version": "v0.2.1",
  "type": "module",
  "description": "Home Assistant Reef Tank Card - TypeScript Strict Version",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "watch": "vite build --watch",
    "watch:prod": "vite build --watch --mode production",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --no-cache"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "vitest": "4.1.7",
    "@vitest/coverage-istanbul": "4.1.7",
    "@vitest/coverage-v8": "4.1.7"   
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-istanbul": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-delete": "^3.0.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "lit": "^3.3.3"
  },
  "keywords": [
    "home-assistant",
    "custom-card",
    "reef-tank",
    "aquarium",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
